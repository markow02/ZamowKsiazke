@model ZamowKsiazke.Models.Order

<h1>Dziękujęmy!</h1>

<h5 class="mt-5">Order Id: @Model.Id</h5>

@if (Model.OrderItems.Count > 0)
{
    <table class="table">
        <thead>
            <tr>
                <th></th>
                <th>Tytuł</th>
                <th>Cena</th>
                <th>Ilość</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.OrderItems)
            {
                var itemTotal = item.Book.Price * item.Quantity;
                <tr>
                    <td>
                        <a class="a-cleanup" asp-controller="Store" asp-action="Details" asp-route-id="@item.Book.Id"><img src="@item.Book.ImageUrl" style="height: 4em" /></a>
                    </td>
                    <td>
                        <a class="a-cleanup" asp-controller="Store" asp-action="Details" asp-route-id="@item.Book.Id">@item.Book.Title</a>
                    </td>
                    <td>
                        @itemTotal.ToString("c")
                    </td>
                    <td>
                        @item.Quantity
                    </td>
                </tr>
            }
        </tbody>

        <tfoot>
            <tr>
                <td></td>
                <td></td> <!-- Added missing empty cell for image column -->
                <td class="text-right">
                    <strong>Suma:</strong>
                </td>
                <td>
                    <strong>@Model.OrderTotal.ToString("c")</strong>
                </td>
                <td></td> <!-- Added missing empty cell for remove button column -->
            </tr>
        </tfoot>
    </table>
}

