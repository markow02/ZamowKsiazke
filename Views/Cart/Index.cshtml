@model ZamowKsiazke.Models.Cart

<h1 class="my-4">Koszyk</h1>

@if (Model.CartItems.Count > 0)
{
    <table class="table table-striped">
        <thead class="thead-dark">
            <tr>
                <th></th> <!-- Image column -->
                <th>Tytuł</th>
                <th>Cena</th>
                <th>Ilość</th>
                <th>Usuń</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.CartItems)
            {
                var bookTotal = item.Book.Price * item.Quantity;
                <tr>
                    <td>
                        <a class="a-cleanup" asp-controller="Store" asp-action="Details" asp-route-id="@item.Book.Id">
                            <img src="@item.Book.ImageUrl" class="img-thumbnail" style="height: 4em" />
                        </a>
                    </td>
                    <td>
                        <a class="a-cleanup" asp-controller="Store" asp-action="Details" asp-route-id="@item.Book.Id" style="text-decoration: none; color: inherit;">
                            @item.Book.Title
                        </a>
                    </td>
                    <td>
                        @bookTotal.ToString("c")
                    </td>
                    <td>
                        <div class="d-flex align-items-center">
                            <a asp-controller="Cart" asp-action="ReduceQuantity" asp-route-id="@item.Book.Id" class="btn btn-outline-secondary btn-sm me-2">
                                <i class="fa-solid fa-minus"></i>
                            </a>
                            <span class="badge bg-primary text-white">@item.Quantity</span>
                            <a asp-controller="Cart" asp-action="IncreaseQuantity" asp-route-id="@item.Book.Id" class="btn btn-outline-secondary btn-sm ms-2">
                                <i class="fa-solid fa-plus"></i>
                            </a>
                        </div>
                    </td>
                    <td>
                        <a asp-controller="Cart" asp-action="RemoveFromCart" asp-route-id="@item.Book.Id" class="btn btn-outline-danger btn-sm">
                            <i class="fa-solid fa-xmark"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <td colspan="2"></td> <!-- Empty cells for image and title columns -->
                <td class="text-end">
                    <strong>Suma:</strong>
                </td>
                <td>
                    <strong>@Model?.GetCartTotal().ToString("c")</strong>
                </td>
                <td></td> <!-- Empty cell for remove button column -->
            </tr>
        </tfoot>
    </table>

    <div class="d-flex justify-content-end mt-4">
        <a class="a-cleanup me-3" asp-controller="Cart" asp-action="ClearCart">
            <button class="btn btn-danger">
                <i class="fa-solid fa-trash-can"></i> Wyczyść koszyk
            </button>
        </a>
        <a class="a-cleanup" asp-controller="Order" asp-action="Checkout">
            <button class="btn btn-success">
                <i class="fa-solid fa-right-to-bracket"></i> Do kasy
            </button>
        </a>
    </div>
}
else
{
    <h3 class="text-center">Twój koszyk jest pusty</h3>
}